rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Support tickets ────────────────────────────────────────────────────────
    // All reads/writes from the student-facing app go via API routes (Admin SDK),
    // which bypasses these rules entirely.
    // Direct client-SDK access is restricted here as a defence-in-depth measure.
    match /support_tickets/{docId} {
      // Authenticated student can read only their own ticket
      allow read: if request.auth != null
                  && request.auth.uid == resource.data.studentUid;

      // Creation is via /api/tickets/create (Admin SDK) — no client writes
      allow create: if false;

      // No client-side updates (admin panel uses Admin SDK via /api/tickets/update)
      allow update: if false;

      allow delete: if false;
    }

    // ── Ticket messages ────────────────────────────────────────────────────────
    // Student replies go via /api/tickets/messages POST (Admin SDK).
    // Admin replies also go via API. No direct client writes needed.
    match /ticket_messages/{messageId} {
      // Authenticated user can read messages — server enforces ticket ownership
      allow read: if request.auth != null;

      // Client-side creation is disabled; use the messages API route
      allow create: if false;

      allow update, delete: if false;
    }

    // ── Ticket counter (meta) ──────────────────────────────────────────────────
    // Only Admin SDK (server-side); no client access
    match /meta/{docId} {
      allow read, write: if false;
    }

    // ── User profiles ──────────────────────────────────────────────────────────
    // Each user can read/write only their own profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

  }
}
